{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(npx tsc:*)",
      "Bash(npm install:*)",
      "Bash(npm ci)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm run build:*)",
      "Bash(npm uninstall:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(ls:*)",
      "Bash(curl:*)",
      "Bash(timeout 5 curl:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Write(*.tsx)",
      "Write(*.ts)",
      "Write(*.css)",
      "Write(*.json)",
      "Write(*.md)",
      "Edit(**/*.tsx)",
      "Edit(**/*.ts)",
      "Edit(**/*.css)",
      "Edit(**/*.json)",
      "Edit(**/*.md)",
      "Read(**)",
      "Grep(**)",
      "mcp__ide__getDiagnostics",
      "mcp__context7__*",
      "mcp__context7__resolve-library-id",
      "mcp__time__*",
      "mcp__time__get_current_time",
      "mcp__supabase__*"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\Windows Ding.wav').PlaySync()",
            "shell": "powershell"
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["context7", "time"]
}

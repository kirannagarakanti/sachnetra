{
  "model": "claude-sonnet-4-6",
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:en.wikipedia.org)",
      "WebFetch(domain:file.scirp.org)",
      "WebFetch(domain:www.nseindia.com)",
      "WebFetch(domain:ssrn.com)",
      "WebFetch(domain:papers.ssrn.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(npx tsc:*)",
      "Bash(npm install:*)",
      "Bash(npm ci)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run type-check:*)",
      "Bash(npm run build:*)",
      "Bash(npm uninstall:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(ls:*)",
      "Bash(curl:*)",
      "Bash(timeout 5 curl:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Write(*.tsx)",
      "Write(*.ts)",
      "Write(*.css)",
      "Write(*.json)",
      "Write(*.md)",
      "Write(ai_docs/learning/**)",
      "Write(scratch/**)",
      "Bash(mkdir:*)",
      "Bash(git clone:*)",
      "Bash(git clone *)",
      "Edit(**/*.tsx)",
      "Edit(**/*.ts)",
      "Edit(**/*.css)",
      "Edit(**/*.json)",
      "Edit(**/*.md)",
      "Read(**)",
      "Grep(**)",
      "mcp__ide__getDiagnostics",
      "mcp__context7__*",
      "mcp__context7__resolve-library-id",
      "mcp__time__*",
      "mcp__time__get_current_time",
      "mcp__supabase__*"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/hooks/allow-web-tools.ps1",
            "shell": "powershell",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\Windows Ding.wav').PlaySync()",
            "shell": "powershell"
          }
        ]
      }
    ]
  },
  "enabledMcpjsonServers": ["context7", "time"]
}
